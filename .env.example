# ─────────────────────────────────────────────────────────────
#  Переменные окружения для бота (Railway → вкладка Variables).
#  Скопируйте в .env для локального запуска или задайте на Railway.
# ─────────────────────────────────────────────────────────────

# Токен от @BotFather (ОБЯЗАТЕЛЬНО задайте свой — старый отозвите через /revoke)
BOT_TOKEN=123456789:AA...

# Telegram user_id администратора(ов). Несколько — через запятую: 111,222
ADMIN_IDS=334618540

# Секрет для защиты вебхука. Произвольная длинная строка.
# В Тильде укажите URL: https://ВАШ-ДОМЕН.up.railway.app/tilda-webhook?secret=ЭТОТ_СЕКРЕТ
TILDA_WEBHOOK_SECRET=придумайте-длинный-секрет

# ID закрытого канала/группы воркшопа (вида -1001234567890).
# Бот должен быть в нём админом с правом создавать ссылки-приглашения.
# Узнать ID: добавьте @userinfobot/@getidsbot в канал, или перешлите пост боту.
WORKSHOP_CHANNEL_ID=-1001234567890

# Необязательные (есть значения по умолчанию в коде):
# WORKSHOP_DATE_STR=07 июня 2025
# WORKSHOP_PRICE=10000
# WORKSHOP_LOCATION=Ссылка появится за день до воркшопа
# DB_PATH=bot.db
# QR_IMAGE_PATH=qr_sbp.png

# PORT задаёт Railway автоматически — локально можно не указывать (по умолчанию 8080).
